@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

set(hackarena3_PACKAGE_PREFIX_DIR "${PACKAGE_PREFIX_DIR}")
set(_hackarena3_vendor_prefix "${hackarena3_PACKAGE_PREFIX_DIR}/vendor")
set(_hackarena3_saved_prefix_path "${CMAKE_PREFIX_PATH}")

if(EXISTS "${_hackarena3_vendor_prefix}/share")
    list(PREPEND CMAKE_PREFIX_PATH "${_hackarena3_vendor_prefix}")
endif()

find_dependency(Protobuf CONFIG REQUIRED)
find_dependency(gRPC CONFIG REQUIRED)
find_dependency(nlohmann_json CONFIG REQUIRED)
find_dependency(Threads REQUIRED)

set(CMAKE_PREFIX_PATH "${_hackarena3_saved_prefix_path}")
unset(_hackarena3_saved_prefix_path)
unset(_hackarena3_vendor_prefix)

include("${CMAKE_CURRENT_LIST_DIR}/hackarena3Targets.cmake")

if(WIN32)
    set(hackarena3_RUNTIME_BIN_DIR "${hackarena3_PACKAGE_PREFIX_DIR}/vendor/bin")

    function(hackarena3_copy_runtime_dlls target_name)
        if(NOT TARGET "${target_name}")
            message(FATAL_ERROR "hackarena3_copy_runtime_dlls: target '${target_name}' does not exist.")
        endif()

        file(GLOB _hackarena3_runtime_dlls "${hackarena3_RUNTIME_BIN_DIR}/*.dll")
        if(_hackarena3_runtime_dlls)
            add_custom_command(
                TARGET "${target_name}" POST_BUILD
                COMMAND "${CMAKE_COMMAND}" -E copy_if_different
                    ${_hackarena3_runtime_dlls}
                    $<TARGET_FILE_DIR:${target_name}>
                VERBATIM
            )
        endif()
    endfunction()
endif()
